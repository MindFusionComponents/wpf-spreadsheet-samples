<Window x:Class="MindFusion.Spreadsheet.Wpf.Samples.CS.Calendar.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
				xmlns:ss="http://mindfusion.eu/spreadsheet/wpf"
        Title="MindFusion.Spreadsheet for WPF Sample: Calendar" Height="350" Width="525" WindowState="Maximized" Icon="/Calendar;component/App.ico">
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>

		<ss:WorkbookView x:Name="workbookView">
			<ss:Workbook x:Name="workbook" />
		</ss:WorkbookView>

		<TextBlock Margin="5" Grid.Row="1" Text="This sample demonstrates a month calendar. The days of the calendar are calculated using a formula. Change the month and year in the top cell to see the calendar update." TextWrapping="Wrap" />

	</Grid>
</Window>
