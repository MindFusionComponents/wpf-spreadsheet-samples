<UserControl x:Class="MindFusion.Spreadsheet.Wpf.Samples.CS.Features.LocalizationPanel"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:ss="http://mindfusion.eu/spreadsheet/wpf"
	xmlns:local="clr-namespace:MindFusion.Spreadsheet.Wpf.Samples.CS.Features"
	Background="White"
	mc:Ignorable="d" d:DesignHeight="300" d:DesignWidth="500">

	<UserControl.Resources>
		<local:LanguageConverter x:Key="LanguageConverter" />
	</UserControl.Resources>
	
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>

		<ss:WorkbookView x:Name="workbookView">
			<ss:WorkbookView.ContextMenu>
				<ContextMenu MenuItem.Click="ContextMenu_Click">
					<MenuItem Header="Conditional Format Form..." />
					<MenuItem Header="Delete Cells Form..." />
					<MenuItem Header="Fill Series Form..." />
					<MenuItem Header="Find Replace Form..." />
					<MenuItem Header="Format Form..." />
					<MenuItem Header="Hyperlink Form..." />
					<MenuItem Header="Insert Cells Form..." />
					<MenuItem Header="Insert Worksheet Form..." />
					<MenuItem Header="Manage NamedRanges Form..." />
					<MenuItem Header="Sort Form..." />
					<MenuItem Header="Validation Form..." />
					<MenuItem Header="Worksheet Rename Form..." />
				</ContextMenu>
			</ss:WorkbookView.ContextMenu>
			<ss:Workbook x:Name="workbook" />
		</ss:WorkbookView>

		<Grid Grid.Row="1">
			<Grid.ColumnDefinitions>
				<ColumnDefinition />
				<ColumnDefinition Width="Auto" />
			</Grid.ColumnDefinitions>
			<TextBlock Text="Choose locale for the workbook from the drop-down control. Check out the localized standard forms through the context menu. Supported languages are highlighted in the combo box." TextWrapping="Wrap" Margin="5" />
			<StackPanel Orientation="Vertical" Grid.Column="1" Width="150" Margin="5">
				<TextBlock Text="Locale:" />
				<ComboBox Name="locale" Margin="0,5,0,0" HorizontalContentAlignment="Stretch">
					<ComboBox.ItemTemplate>
						<DataTemplate>
							<Border Background="{Binding Converter={StaticResource LanguageConverter}}">
								<TextBlock Text="{Binding}" />
							</Border>
						</DataTemplate>
					</ComboBox.ItemTemplate>
				</ComboBox>	
			</StackPanel>
		</Grid>

	</Grid>

</UserControl>
