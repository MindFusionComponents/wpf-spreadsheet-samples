<UserControl x:Class="MindFusion.Spreadsheet.Wpf.Samples.CS.Features.AnnotationsPanel"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:ss="http://mindfusion.eu/spreadsheet/wpf"
	Background="White"
	mc:Ignorable="d" d:DesignHeight="300" d:DesignWidth="500">

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>

		<ss:WorkbookView x:Name="workbookView">
			<ss:Workbook x:Name="workbook" />
		</ss:WorkbookView>

		<Grid Grid.Row="1">
			<Grid.ColumnDefinitions>
				<ColumnDefinition />
				<ColumnDefinition Width="Auto" />
			</Grid.ColumnDefinitions>
			<TextBlock Text="Select a cell in the worksheet and press the 'Add / Remove Annotation' button. Toggle the visibility of the annotation by using the 'Show Always' checkbox." TextWrapping="Wrap" Margin="5" />
			<StackPanel Orientation="Vertical" Width="150" Grid.Column="1" Margin="5">
				<Button Content="Add / Remove Annotation" Click="Button_Click" />
				<CheckBox Name="checkBox" Content="Show Always" Margin="0,5,0,0" Checked="CheckBox_Checked" Unchecked="CheckBox_Unchecked" />
			</StackPanel>
		</Grid>

	</Grid>

</UserControl>
