<UserControl x:Class="MindFusion.Spreadsheet.Wpf.Samples.CS.Features.PrintingPanel"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:ss="http://mindfusion.eu/spreadsheet/wpf"
	Background="White"
	mc:Ignorable="d" d:DesignHeight="300" d:DesignWidth="500">

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>

		<ss:WorkbookView x:Name="workbookView">
			<ss:Workbook x:Name="workbook" />
		</ss:WorkbookView>

		<Grid Grid.Row="1">
			<Grid.ColumnDefinitions>
				<ColumnDefinition />
				<ColumnDefinition Width="Auto" />
			</Grid.ColumnDefinitions>
			<StackPanel Orientation="Vertical" Grid.Column="1" Width="150" Margin="5">
				<Button Name="previewButton" Content="Preview..." Click="previewButton_Click" />
				<Button Name="printButton" Content="Print..." Margin="0,5,0,0" Click="printButton_Click" />
			</StackPanel>
		</Grid>

	</Grid>

</UserControl>
