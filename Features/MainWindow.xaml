<Window x:Class="MindFusion.Spreadsheet.Wpf.Samples.CS.Features.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
				xmlns:ss="http://mindfusion.eu/spreadsheet/wpf"
        Title="MindFusion.Spreadsheet for WPF Sample: Features" Height="350" Width="525" WindowState="Maximized" Icon="/Features;component/App.ico">
	<Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="200" />
			<ColumnDefinition />
		</Grid.ColumnDefinitions>

		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition />
			</Grid.RowDefinitions>

			<TextBlock Text="Double-click on an item in the list below to open the respective form" TextWrapping="Wrap" Margin="5" />
			<ListView Name="listView" Grid.Row="1">
				<ListView.ItemContainerStyle>
					<Style TargetType="ListViewItem">
						<EventSetter Event="MouseDoubleClick" Handler="listViewItem_MouseDoubleClick" />
					</Style>
				</ListView.ItemContainerStyle>
			</ListView>

		</Grid>

		<Grid Name="contentPanel" Grid.Column="1">
		</Grid>

	</Grid>
</Window>
